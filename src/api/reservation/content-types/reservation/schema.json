{
  "kind": "collectionType",
  "collectionName": "reservations",
  "info": {
    "singularName": "reservation",
    "pluralName": "reservations",
    "displayName": "Reservation"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "contact_number": {
      "type": "integer"
    },
    "event_date": {
      "type": "date"
    },
    "event_time": {
      "type": "time"
    },
    "package": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::package.package"
    },
    "notes": {
      "type": "text"
    },
    "progress": {
      "type": "enumeration",
      "enum": [
        "pending",
        "confirmed",
        "cancelled",
        "done"
      ]
    },
    "payment": {
      "type": "boolean"
    },
    "url": {
      "type": "string",
      "maxLength": 30,
      "unique": true
    },
    "address": {
      "type": "text"
    }
  }
}
